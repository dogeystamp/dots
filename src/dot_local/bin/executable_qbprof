#!/bin/sh
# runs a qutebrowser profile

if [ -z "$1" ]; then
	printf "No profile selected.\n" > /dev/stderr
	exit 1
fi

# https://github.com/qutebrowser/qutebrowser/issues/8908
export QTWEBENGINE_FORCE_USE_GBM=0

if [ "$1" = "dsc" ]; then
	if [ "$(timew get dom.active)" = "1" ]; then
		notify-send -a "QBPROF" "clock out first"
		exit 1
	fi
fi

qutebrowser --basedir ~/.config/qbprof/"$1"
